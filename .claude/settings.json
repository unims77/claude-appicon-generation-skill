{
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Task(*)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "Skill(*)",
      "ToolSearch(*)",
      "NotebookEdit(*)",
      "WebSearch",
      "WebSearch(*)",
      "SendMessage(*)",
      "TeamCreate(*)",
      "TeamDelete(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "EnterPlanMode(*)",
      "AskUserQuestion(*)",
      "ListMcpResourcesTool(*)",
      "ReadMcpResourceTool(*)",
      "mcp__context7__*",
      "mcp__memory__*",
      "mcp__github__*",
      "mcp__fetch__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "WebFetch",
      "WebFetch(*)",
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)*",
      "Bash(rm -r .)*",
      "Bash(rm -r ./)*",
      "Bash(rm -rf *)*",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(>/dev/*)",
      "Bash(curl*|*sh)*",
      "Bash(wget*|*sh)*",
      "Bash(*>~/.ssh/*)",
      "Bash(*>~/.zshrc)*",
      "Bash(*>~/.bashrc)*",
      "Bash(*>~/.profile)*",
      "Bash(git push --force*main)*",
      "Bash(git push -f*main)*",
      "Bash(git push --force*master)*",
      "Bash(git push -f*master)*",
      "Bash(git reset --hard origin/*)*",
      "Bash(git clean -f*)*",
      "Bash(git checkout -- .)*",
      "Bash(git restore .)*",
      "Bash(docker system prune)*",
      "Bash(mkfs*)*",
      "Bash(dd if=*)*",
      "Bash(eval *)*",
      "Bash(bash -c *)*",
      "Bash(sh -c *)*"
    ]
  }
}
